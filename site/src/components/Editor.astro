---
interface Props {
  /** タイトルバーに出すファイル名 */
  file: string;
  /** ファイル名の右に出す診断バッジ（例: "✗ 1"）。省略可 */
  badge?: string;
  /** バッジの文字色 */
  badgeColor?: string;
  /** エディタ枠の max-width（例: "760px"）。省略時は無制限 */
  maxWidth?: string;
}

const { file, badge, badgeColor, maxWidth } = Astro.props;
---

<div class="editor" style={maxWidth ? `max-width:${maxWidth}` : undefined}>
  <div class="titlebar">
    <span class="dot" style="background:#f92672"></span>
    <span class="dot" style="background:#e6db74"></span>
    <span class="dot" style="background:#a6e22e"></span>
    <span style="margin-left:2px">{file}</span>
    {badge && <span style={`color:${badgeColor};margin-left:6px;`}>{badge}</span>}
  </div>
  <slot />
</div>
