---
import Section from "../Section.astro";
import SwatchGrid from "../SwatchGrid.astro";
import { diff } from "../../data/palette";

// Unified（インライン）と Split（左右分割）の 2 レイアウトを再現。波括弧・記号を含むため set:html で出力する。
const unifiedDiff = `<div class="dh">loos-monokai.json <span class="stat-add">+3</span> <span class="stat-del">−2</span><span style="margin-left:auto;color:var(--brown);">Unified</span></div>
<div class="dhunk">@@ -103,4 +103,4 @@ "style"</div>
<pre><div class="dl del bar-mod"><span class="go">103</span><span class="gn"></span><span class="sg">−</span><span class="tx"><span class="jkey">"info"</span>: "<span class="w-del">#819aff</span>",</span></div><div class="dl add bar-mod"><span class="go"></span><span class="gn">103</span><span class="sg">+</span><span class="tx"><span class="jkey">"info"</span>: "<span class="w-add">#4197f1</span>",</span></div><div class="dl del bar-mod"><span class="go">104</span><span class="gn"></span><span class="sg">−</span><span class="tx"><span class="jkey">"info.background"</span>: "<span class="w-del">#546190</span>",</span></div><div class="dl add bar-mod"><span class="go"></span><span class="gn">104</span><span class="sg">+</span><span class="tx"><span class="jkey">"info.background"</span>: "<span class="w-add">#3c708c</span>",</span></div><div class="dl"><span class="go">105</span><span class="gn">105</span><span class="sg"> </span><span class="tx">  <span class="jkey">"info.border"</span>: "#4197f1",</span></div></pre>
<div class="dhunk">@@ -150,3 +150,4 @@ "syntax"</div>
<pre><div class="dl"><span class="go">150</span><span class="gn">150</span><span class="sg"> </span><span class="tx">  <span class="jkey">"property"</span>: { "color": "#f4f4ec" },</span></div><div class="dl add bar-add"><span class="go"></span><span class="gn">151</span><span class="sg">+</span><span class="tx">  <span class="jkey">"property.json_key"</span>: { "color": "<span class="w-add">#60d6ec</span>" },</span></div><div class="dl"><span class="go">151</span><span class="gn">152</span><span class="sg"> </span><span class="tx">  <span class="jkey">"selector"</span>: { "color": "#9ed72b" },</span></div></pre>`;

const splitDiff = `<div class="dh">loos-monokai.json <span class="stat-add">+3</span> <span class="stat-del">−2</span><span style="margin-left:auto;color:var(--brown);">Split</span></div>
<div class="diff-split">
  <div class="side">
    <div class="ds-l"><span class="n">36</span><span class="c"><span class="pun">  });</span></span></div>
    <div class="ds-l del"><span class="n">103</span><span class="c"><span class="jkey">"info"</span>: "<span class="w-del">#819aff</span>",</span></div>
    <div class="ds-l del"><span class="n">104</span><span class="c"><span class="jkey">"info.background"</span>: "<span class="w-del">#546190</span>",</span></div>
    <div class="ds-l"><span class="n">105</span><span class="c"><span class="jkey">"info.border"</span>: "#4197f1",</span></div>
    <div class="ds-l hatch"><span class="n"></span><span class="c"></span></div>
    <div class="ds-l"><span class="n">150</span><span class="c"><span class="jkey">"property"</span>: { ... },</span></div>
  </div>
  <div class="side">
    <div class="ds-l"><span class="n">36</span><span class="c"><span class="pun">  });</span></span></div>
    <div class="ds-l add"><span class="n">103</span><span class="c"><span class="jkey">"info"</span>: "<span class="w-add">#4197f1</span>",</span></div>
    <div class="ds-l add"><span class="n">104</span><span class="c"><span class="jkey">"info.background"</span>: "<span class="w-add">#3c708c</span>",</span></div>
    <div class="ds-l"><span class="n">105</span><span class="c"><span class="jkey">"info.border"</span>: "#4197f1",</span></div>
    <div class="ds-l add"><span class="n">151</span><span class="c"><span class="w-add"><span class="jkey">"property.json_key"</span>: { ... },</span></span></div>
    <div class="ds-l"><span class="n">150</span><span class="c"><span class="jkey">"property"</span>: { ... },</span></div>
  </div>
</div>`;
---

<Section title="4. diff 系" tag="Git">
  <SwatchGrid items={diff} />
  <div class="diff" set:html={unifiedDiff} />
  <div class="diff" set:html={splitDiff} />
</Section>
