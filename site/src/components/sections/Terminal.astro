---
import Section from '../Section.astro';
import Editor from '../Editor.astro';
import AnsiGrid from '../AnsiGrid.astro';

// 統合ターミナルでの CLI 出力の色味。normal / bright の両方を再現する。
const term = `<span class="t-grn">ryo</span><span class="t-fg"> in </span><span class="t-cyn">~/dotfiles</span><span class="t-pur"> on </span><span class="t-red"> master</span><span class="t-yel"> ✗</span>
<span class="t-blu">❯</span><span class="t-fg"> eza -l --git</span>
<span class="t-blu">drwxr-xr-x</span><span class="t-fg">  - ryo </span><span class="t-grn">30 May 14:30</span><span class="t-cyn"> zed</span>
<span class="t-fg">.rw-r--r--  4.3k ryo </span><span class="t-grn">30 May 12:47</span><span class="t-fg"> loos-monokai.json</span>
<span class="t-fg">.rw-r--r--  9.0k ryo </span><span class="t-grn">30 May 14:13</span><span class="t-yel"> loos-monokai.html</span>

<span class="t-blu">❯</span><span class="t-fg"> git status -s</span>
<span class="t-grn">M </span><span class="t-fg"> themes/loos-monokai.json</span>
<span class="t-red">?? </span><span class="t-fg">loos-monokai.html</span>

<span class="t-blu">❯</span><span class="t-fg"> git diff</span>
<span class="t-yel">@@ -56,1 +56,1 @@</span>
<span class="t-red">-  "info": "#819aff"</span>
<span class="t-grn">+  "info": "#3db1f5"</span>

<span class="t-mag">WARN</span><span class="t-fg">  deprecated option</span>   <span class="t-cyn">INFO</span><span class="t-fg">  build complete</span>   <span class="t-red">ERR</span><span class="t-fg">  not found</span>

<span class="t-blu">❯</span><span class="t-fg"> # normal vs bright（上:通常 / 下:bright）</span>
<span class="t-dim">normal </span><span class="t-red">██ </span><span class="t-grn">██ </span><span class="t-yel">██ </span><span class="t-blu">██ </span><span class="t-mag">██ </span><span class="t-cyn">██ </span><span class="t-fg">██</span>
<span class="t-dim">bright </span><span class="b-red">██ </span><span class="b-grn">██ </span><span class="b-yel">██ </span><span class="b-blu">██ </span><span class="b-mag">██ </span><span class="b-cyn">██ </span><span class="b-wht">██</span>
<span class="t-dim"># bright はコードのシンタックス色とほぼ同じ鮮やかさ</span>
<span class="t-blu">❯</span><span class="t-fg"> </span><span class="cursor">█</span>`;

const termBright = `<span class="t-dim"># 1. プロンプト（bold＝bright で強調）</span>
<span class="b-grn">ryo</span><span class="t-dim"> in </span><span class="b-cyn">~/dotfiles</span><span class="t-dim"> on </span><span class="b-mag"> master</span><span class="b-red"> ✗</span> <span class="t-dim">12:58</span>
<span class="b-blu">❯</span><span class="t-fg"> pnpm build</span>

<span class="t-dim"># 2. ビルド／ログのステータス</span>
<span class="b-grn">✓</span><span class="t-fg"> 142 modules transformed</span>
<span class="b-yel">⚠</span><span class="t-fg">  WARN  </span><span class="t-dim">"sass" legacy API is deprecated</span>
<span class="b-red">✗</span><span class="t-fg">  ERROR </span><span class="t-dim">Cannot find module './foo'</span>
<span class="b-cyn">ℹ</span><span class="t-fg">  built in </span><span class="b-grn">1.24s</span>

<span class="t-dim"># 3. git log（ハッシュ＝bright black＝グレー）</span>
<span class="b-yel">*</span><span class="b-blk"> dbe07cf</span><span class="t-fg"> update skills </span><span class="b-cyn">(HEAD -&gt; master)</span>
<span class="b-blk"> adb48c0</span><span class="t-fg"> fix: deny-check.sh </span><span class="b-blk">(2 days ago) </span><span class="b-blu">ddryo</span>

<span class="t-dim"># 4. eza（ディレクトリ＝bright blue, 実行可＝bright green）</span>
<span class="b-blu">zed</span><span class="t-fg">  </span><span class="b-grn">deploy.sh</span><span class="t-fg">  </span><span class="b-blk">.gitignore</span><span class="t-fg">  README.md</span>

<span class="t-dim"># 5. rg のマッチ強調（行番号＝bright green, 一致＝bright red）</span>
<span class="b-mag">loos-monokai.json</span>
<span class="b-grn">103</span><span class="t-fg">:  "info": "</span><span class="b-red">#3db1f5</span><span class="t-fg">",</span>
<span class="b-blu">❯</span><span class="t-fg"> </span><span class="cursor">█</span>`;
---

<Section title="6. ターミナル ANSI" tag="統合ターミナル">
  <AnsiGrid />

  <Editor file="zsh — 80×24" maxWidth="760px">
    <pre class="term" set:html={term}></pre>
  </Editor>
  <p class="note">
    テーマの <code>terminal.ansi.*</code> をそのまま使用。Zed 内蔵ターミナルでのCLI出力の色味です。
  </p>

  <h2 style="border:0; margin-top:28px; font-size:14px; color:var(--linenum);">bright の実使用シーン</h2>
  <Editor file="zsh — bright examples" maxWidth="760px">
    <pre class="term" set:html={termBright}></pre>
  </Editor>
  <p class="note">
    緑✓＝成功 / 黄⚠＝警告 / 赤✗＝エラー / <code>bright black</code>＝控えめなグレー（ハッシュ・日時）。すべて bright 側＝コードと同じ鮮やかな Monokai 色です。
  </p>
</Section>
