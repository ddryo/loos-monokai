---
import Section from "../Section.astro";
import SwatchGrid from "../SwatchGrid.astro";
import Editor from "../Editor.astro";
import { highlight } from "../../data/palette";

// document_highlight は write/read 同色。selection/search と並べて確認するコード見本。
const parseArgs = `<span class="ln"><span class="c">// カーソル位置の "args" と同名シンボルが全てハイライトされる</span></span><span class="ln"><span class="kd">const</span> <span class="pun hl-write">args</span> <span class="pun">=</span> <span class="pun">process.</span><span class="fn">argv</span><span class="pun">.</span><span class="fn">slice</span><span class="pun">(</span><span class="num">2</span><span class="pun">);</span>          <span class="c">← 宣言＝write</span></span><span class="ln"><span class="kd">const</span> <span class="pun">idx</span> <span class="pun">=</span> <span class="pun hl-read">args</span><span class="pun">.</span><span class="fn">indexOf</span><span class="pun">(</span><span class="str">'--threshold'</span><span class="pun">);</span>   <span class="c">← 参照＝read</span></span><span class="ln"><span class="kd">const</span> <span class="pun">rest</span> <span class="pun">=</span> <span class="pun hl-read">args</span><span class="pun">.</span><span class="fn">filter</span><span class="pun">(</span><span class="pun">(</span><span class="par">a</span><span class="pun">)</span> <span class="kw">=&gt;</span> <span class="par">a</span><span class="pun">[</span><span class="num">0</span><span class="pun">]</span> <span class="kw">!==</span> <span class="str">'-'</span><span class="pun">);</span>  <span class="c">← 参照＝read</span></span><span class="ln"></span><span class="ln"><span class="kd">const</span> <span class="pun">label</span> <span class="pun">=</span> <span class="str hl-sel">'ja-translation-helper'</span><span class="pun">;</span>   <span class="c">← ダブルクリックで選択＝selection</span></span><span class="ln"><span class="kd">const</span> <span class="pun hl-find">lang</span><span class="pun">Key</span> <span class="pun">=</span> <span class="fn">get</span><span class="fn hl-find">Lang</span><span class="pun">(</span><span class="pun">current</span><span class="pun hl-find">Lang</span><span class="pun">);</span> <span class="c">← 検索 "lang" の一致＝search</span></span>`;
---

<Section title="3. 選択・ハイライト" tag="背景フィル" tagCustom>
  <SwatchGrid items={highlight} />
  <Editor
    file="parse-args.ts"
    badge="— カーソルを args に置いた状態"
    badgeColor="var(--linenum)"
    maxWidth="760px"
  >
    <pre set:html={parseArgs} />
  </Editor>
</Section>
