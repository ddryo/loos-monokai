---
import Section from "../Section.astro";
import SwatchGrid from "../SwatchGrid.astro";
import { chrome } from "../../data/palette";

// Zed の UI クローム全体を再現したモックアップ。波括弧を含むコード行があるため set:html で出力する。
// 中身はパレット確認用の汎用ダミー（app.js を開いた状態）。シグネチャ用ポップアップは下側に出す。
const zedMockup = `<div class="z-title">
  <span class="dot" style="background:#f92672"></span><span class="dot" style="background:#e6db74"></span><span class="dot" style="background:#a6e22e"></span>
  <span style="margin-left:6px;">project-name</span>
</div>
<div class="z-side">
  <div class="z-row d0">▾ project-name</div>
  <div class="z-row d1">style.css</div>
  <div class="z-row d1 sel">app.js</div>
</div>
<div class="z-main">
  <div class="z-tabs">
    <span class="z-nav">←　→</span>
    <div class="z-tab active">app.js</div>
    <div class="z-tab">style.css</div>
  </div>
  <div class="z-bread">
    <span class="crumb">app.js</span><span class="sep">›</span><span class="crumb">hello</span>
  </div>
  <div class="z-edit">
    <div class="z-gutter"><span>1</span><span>2</span><span>3</span><span>4</span><span class="cur">5</span></div>
    <div class="z-code">
      <span class="l"><span class="kd">function</span> <span class="fn">hello</span><span class="pun">() {</span></span>
      <span class="l">  <span class="pun">console</span><span class="pun">.</span><span class="fn">log</span><span class="pun">(</span><span class="str">"Hello"</span><span class="pun">);</span></span>
      <span class="l"><span class="pun">}</span></span>
      <span class="l"> </span>
      <span class="l active"><span class="fn z-hover">hello</span><span class="pun">();</span></span>
    </div>
    <div class="z-pop"><span class="kd">function</span> <span class="pun">hello</span><span class="pun">(): </span><span class="kw">void</span></div>
  </div>
</div>
<div class="z-status">
  <span style="margin-left:auto; color:#90908a;">5:1</span>
  <span style="color:#90908a;">JavaScript</span>
  <span style="color:#90908a;">□</span>
</div>`;
---

<Section title="2. 背景・UI クローム" tag="純正">
  <SwatchGrid items={chrome} />
  <div class="zed" set:html={zedMockup} />
</Section>
