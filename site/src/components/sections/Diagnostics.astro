---
import Section from "../Section.astro";
import SwatchGrid from "../SwatchGrid.astro";
import Editor from "../Editor.astro";
import { diagnostics } from "../../data/palette";

// LSP の error / warning / info。波線アンダーライン + ポップアップを再現（波括弧を含むため set:html）。
const diagErr = `<div class="diag-code"><span class="kd">const</span> <span class="pun">port</span><span class="pun">: </span><span class="ty">number</span> <span class="pun">= </span><span class="str sq-err">'8080'</span><span class="pun">;</span></div>
<div class="diag-pop err"><span class="sev">✗ error</span>Type <code>'string'</code> is not assignable to type <code>'number'</code>.<span class="src">ts(2322)</span></div>`;

const diagWarn = `<div class="diag-code"><span class="kw">export</span> <span class="kw">default</span> <span class="kd">function</span> <span class="fn">Card</span><span class="pun">({ </span><span class="par sq-warn">layout</span> <span class="pun">= </span><span class="str">'withSide'</span><span class="pun">, </span><span class="par">className</span><span class="pun"> }) {</span></div>
<div class="diag-pop warn"><span class="sev">⚠ warning</span>Parameter <code>'layout'</code> is declared but never used.<span class="src">help: Consider removing this parameter.</span></div>`;

const diagInfo = `<div class="diag-code"><span class="kw sq-info">await</span> <span class="fn">fetchData</span><span class="pun">();</span></div>
<div class="diag-pop info"><span class="sev">ℹ info</span><code>'await'</code> has no effect on the type of this expression.<span class="src">ts(80007)</span></div>`;
---

<Section title="5. 診断ポップアップ" tag="独自背景" tagCustom>
  <SwatchGrid items={diagnostics} />

  <div class="columns">
    <div>
      <Editor file="config.ts" badge="✗ 1" badgeColor="var(--red)">
        <Fragment set:html={diagErr} />
      </Editor>
    </div>

    <div>
      <Editor file="Card.jsx" badge="⚠ 1" badgeColor="var(--byellow)">
        <Fragment set:html={diagWarn} />
      </Editor>
    </div>

    <div>
      <Editor file="fetch.ts" badge="ℹ 1" badgeColor="var(--blue)">
        <Fragment set:html={diagInfo} />
      </Editor>
    </div>
  </div>
</Section>
